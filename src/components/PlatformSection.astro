---
import { PLATFORM, STUDIO, REGISTRY, GUARD, EXCHANGE, ECOSYSTEM_SUMMARY } from '../content/copy';
---

<section id="platform" class="eco-header">
  <div class="container">
    <p class="eyebrow">{PLATFORM.number} — {PLATFORM.eyebrow}</p>
    <h2>{PLATFORM.headline}</h2>
  </div>
</section>

<!-- STUDIO -->
<section class="product">
  <div class="container product-grid">
    <div class="product-index">
      <div class="index-num">{STUDIO.index}</div>
      <div class="index-tag"><a href="/studio">{STUDIO.tag}</a></div>
    </div>
    <div class="product-body">
      <h3><a href="/studio">{STUDIO.title}</a></h3>
      <p class="layer-label">{STUDIO.layerLabel}</p>
      <p class="body-text">{STUDIO.body}</p>

      <div class="io-grid">
        <div>
          <p class="col-label">Input</p>
          <div class="plain-list">
            {STUDIO.input.map((item) => <div>{item}</div>)}
          </div>
        </div>
        <div>
          <p class="col-label">Output</p>
          <p class="output-value">{STUDIO.output}</p>
        </div>
      </div>

      <div class="example">
        <p class="example-before">{STUDIO.exampleBefore}</p>
        <p class="example-arrow">↓ becomes</p>
        <pre><code>{STUDIO.exampleAfter}</code></pre>
      </div>

      <p class="summary">{STUDIO.summary}</p>
    </div>
  </div>
</section>

<!-- REGISTRY -->
<section class="product alt">
  <div class="container product-grid">
    <div class="product-index">
      <div class="index-num">{REGISTRY.index}</div>
      <div class="index-tag"><a href="/registry">{REGISTRY.tag}</a></div>
    </div>
    <div class="product-body">
      <h3><a href="/registry">{REGISTRY.title}</a></h3>
      <p class="layer-label">{REGISTRY.layerLabel}</p>
      <p class="body-text">{REGISTRY.body}</p>
      <p class="analogy">{REGISTRY.analogy}</p>

      <div class="version-chain">
        {REGISTRY.versionChain.map((v, i) => (
          <>
            <span class:list={['version-node', { accent: i === REGISTRY.versionChain.length - 1 }]}>{v}</span>
            {i < REGISTRY.versionChain.length - 1 && <span class="chain-arrow">→</span>}
          </>
        ))}
      </div>

      <div class="questions">
        {REGISTRY.questions.map((q) => <div>— {q}</div>)}
      </div>

      <p class="summary">{REGISTRY.summary}</p>
    </div>
  </div>
</section>

<!-- GUARD -->
<section class="product">
  <div class="container product-grid">
    <div class="product-index">
      <div class="index-num">{GUARD.index}</div>
      <div class="index-tag"><a href="/guard">{GUARD.tag}</a></div>
    </div>
    <div class="product-body">
      <h3><a href="/guard">{GUARD.title}</a></h3>
      <p class="layer-label">{GUARD.layerLabel}</p>
      <p class="body-text">{GUARD.body}</p>

      <div class="guard-flow">
        <div class="flow-box">{GUARD.flowBoxes[0]}</div>
        <div class="flow-arrow-label">{GUARD.flowLabels[0]} ↓</div>
        <div class="flow-box accent">{GUARD.flowBoxes[1]}</div>
        <div class="flow-arrow-label">{GUARD.flowLabels[1]} ↓</div>
        <div class="flow-box">{GUARD.flowBoxes[2]}</div>
      </div>

      <div class="mcp-note">
        <p class="mcp-note-body">
          Guard is an MCP (Model Context Protocol) integration. Wrap a server you already run —
          GitHub, Postgres, Stripe — with zero code changes:
        </p>
        <code class="mcp-note-cmd">{GUARD.mcpDetail.install}</code>
      </div>

      <p class="summary">{GUARD.summary}</p>
      <a class="detail-link" href="/guard">How Guard works — two integration paths →</a>
    </div>
  </div>
</section>

<!-- EXCHANGE -->
<section class="product alt">
  <div class="container product-grid">
    <div class="product-index">
      <div class="index-num">{EXCHANGE.index}</div>
      <div class="index-tag"><a href="/exchange">{EXCHANGE.tag}</a></div>
    </div>
    <div class="product-body">
      <h3><a href="/exchange">{EXCHANGE.title}</a></h3>
      <p class="layer-label">{EXCHANGE.layerLabel}</p>

      <div class="analogy-grid">
        {EXCHANGE.analogyList.map((row) => (
          <div class:list={['analogy-cell', { accent: row.accent }]}>
            <div class="platform-name">{row.platform}</div>
            <div class="product-name">{row.product}</div>
          </div>
        ))}
      </div>

      <p class="col-label">Already publishing</p>
      <div class="publisher-list">
        {EXCHANGE.publisherExamples.map((row) => (
          <div>
            {row.publisher} — <span class="artifact">{row.artifact}</span>
          </div>
        ))}
      </div>

      <div class="verbs">
        {EXCHANGE.verbs.map((v) => <span>{v}</span>)}
      </div>

      <p class="summary">{EXCHANGE.summary}</p>
    </div>
  </div>
</section>

<!-- SUMMARY TABLE -->
<section class="eco-summary">
  <div class="summary-grid">
    <div class="th">Layer</div>
    <div class="th">Function</div>
    <div class="th">Simple phrase</div>

    {ECOSYSTEM_SUMMARY.rows.map((row, i) => (
      <>
        <div class:list={['td', { accent: i === 0, last: i === ECOSYSTEM_SUMMARY.rows.length - 1 }]}>{row[0]}</div>
        <div class:list={['td', 'muted', { last: i === ECOSYSTEM_SUMMARY.rows.length - 1 }]}>{row[1]}</div>
        <div class:list={['td', 'muted', { last: i === ECOSYSTEM_SUMMARY.rows.length - 1 }]}>{row[2]}</div>
      </>
    ))}
  </div>
</section>

<style>
  .eco-header {
    padding: 120px 0 60px;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 20px;
  }

  .eco-header h2 {
    font-family: var(--font-serif);
    font-weight: var(--font-medium);
    font-size: clamp(28px, 3.6vw, 46px);
    line-height: 1.15;
    margin: 0;
  }

  .product {
    padding: 120px 0;
  }

  .product.alt {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-primary);
    border-bottom: 1px solid var(--border-primary);
  }

  .product-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 64px;
  }

  .product-index,
  .product-body {
    min-width: 0;
  }

  .index-num {
    font-family: var(--font-serif);
    font-size: 56px;
    color: var(--border-strong);
    line-height: 1;
    margin-bottom: 20px;
  }

  .index-tag {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: 0.08em;
    color: var(--accent);
  }

  h3 {
    font-family: var(--font-serif);
    font-weight: var(--font-medium);
    font-size: clamp(26px, 3vw, 38px);
    margin: 0 0 8px;
  }

  h3 a {
    transition: color var(--transition-fast);
  }

  h3 a:hover {
    color: var(--accent);
  }

  .index-tag a {
    transition: color var(--transition-fast);
  }

  .layer-label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 28px;
  }

  .body-text {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 640px;
    margin-bottom: 32px;
  }

  .col-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 14px;
  }

  .io-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    margin-bottom: 48px;
  }

  .plain-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: var(--text-base);
    color: var(--text-secondary);
  }

  .output-value {
    font-size: var(--text-base);
    color: var(--accent);
  }

  .example {
    background: var(--bg-primary);
    border: 1px solid var(--border-primary);
    padding: 32px;
    margin-bottom: 28px;
  }

  .example-before {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--text-secondary);
    margin-bottom: 20px;
  }

  .example-arrow {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    margin-bottom: 20px;
  }

  .example pre {
    margin: 0;
    overflow-x: auto;
  }

  .example code {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.8;
    color: var(--text-secondary);
    white-space: pre;
  }

  .analogy {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--text-primary);
    margin-bottom: 32px;
  }

  .version-chain {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    margin-bottom: 40px;
  }

  .version-node {
    border: 1px solid var(--border-strong);
    padding: 12px 18px;
    color: var(--text-secondary);
  }

  .version-node.accent {
    border-color: var(--accent);
    color: var(--accent);
  }

  .chain-arrow {
    color: var(--accent);
  }

  .questions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px 32px;
    font-size: var(--text-base);
    color: var(--text-secondary);
    margin-bottom: 28px;
  }

  .guard-flow {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 420px;
    margin-bottom: 32px;
  }

  .flow-box {
    width: 100%;
    padding: 16px 20px;
    border: 1px solid var(--border-strong);
    text-align: center;
  }

  .flow-box.accent {
    border-color: var(--accent);
    color: var(--accent);
  }

  .flow-arrow-label {
    text-align: center;
    width: 100%;
    color: var(--accent);
    padding: 10px 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .analogy-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border-primary);
    border: 1px solid var(--border-primary);
    margin-bottom: 48px;
  }

  .analogy-cell {
    background: var(--bg-primary);
    padding: 24px 16px;
    text-align: center;
  }

  .analogy-cell.accent {
    background: color-mix(in oklch, var(--accent) 10%, var(--bg-primary));
  }

  .platform-name {
    font-size: var(--text-sm);
    margin-bottom: 8px;
  }

  .analogy-cell.accent .platform-name {
    color: var(--accent);
  }

  .product-name {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .analogy-cell.accent .product-name {
    color: var(--accent);
  }

  .publisher-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
    font-size: var(--text-base);
    color: var(--text-secondary);
    margin-bottom: 40px;
  }

  .artifact {
    color: var(--text-primary);
  }

  .verbs {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    margin-bottom: 28px;
  }

  .summary {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: var(--accent);
    margin: 0;
  }

  .mcp-note {
    border: 1px solid var(--border-primary);
    padding: 24px 28px;
    max-width: 640px;
    margin-bottom: 32px;
  }

  .mcp-note-body {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0 0 16px;
  }

  .mcp-note-cmd {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    background: var(--bg-elevated);
    border: 1px solid var(--border-primary);
    padding: 8px 14px;
  }

  .detail-link {
    display: inline-block;
    margin-top: 20px;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: 0.04em;
    color: var(--accent);
    border-bottom: 1px solid var(--accent);
    padding-bottom: 2px;
  }

  .eco-summary {
    padding: 100px 0;
    max-width: 1000px;
    margin: 0 auto;
  }

  .summary-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1.4fr;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: 0 48px;
  }

  .th {
    padding: 16px 0;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: var(--text-xs);
    border-bottom: 1px solid var(--border-strong);
  }

  .td {
    padding: 18px 0;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-primary);
  }

  .td.last {
    border-bottom: none;
  }

  .td.accent {
    color: var(--accent);
  }

  @media (max-width: 760px) {
    .product-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .io-grid,
    .questions {
      grid-template-columns: 1fr;
    }
    .analogy-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .summary-grid {
      padding: 0 24px;
      font-size: 12px;
    }
  }
</style>
