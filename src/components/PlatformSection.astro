---
import { PLATFORM, EXCHANGE_THESIS } from '../content/copy';
import PlatformCard from './PlatformCard.astro';
---

<section id="platform" class="platform">
  <div class="container">
    <p class="muted-eyebrow">{PLATFORM.eyebrow}</p>
    <h2>{PLATFORM.headline}</h2>

    <div class="grid">
      {PLATFORM.products.map((p) => (
        <PlatformCard name={p.name} tagline={p.tagline} body={p.body} />
      ))}
    </div>

    <div class="thesis">
      <p class="thesis-label">{EXCHANGE_THESIS.label}</p>
      {EXCHANGE_THESIS.paragraphs.map((p) => (
        <p class="thesis-p">{p}</p>
      ))}
    </div>
  </div>
</section>

<style>
  .platform {
    padding: 120px 0;
  }

  .muted-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 20px;
  }

  h2 {
    font-family: var(--font-serif);
    font-weight: var(--font-medium);
    font-size: clamp(28px, 3.4vw, 42px);
    line-height: var(--leading-snug);
    max-width: 14ch;
    margin: 0 0 56px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1px;
    background: var(--border-primary);
    border: 1px solid var(--border-primary);
    margin-bottom: 88px;
  }

  .thesis {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }

  .thesis-label {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-2xl);
    color: var(--accent);
    margin-bottom: 28px;
  }

  .thesis-p {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    margin-bottom: 12px;
  }

  .thesis-p:last-child {
    margin-bottom: 0;
    color: var(--text-primary);
    font-weight: var(--font-medium);
  }
</style>
