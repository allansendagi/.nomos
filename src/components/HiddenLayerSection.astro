---
import { HIDDEN_LAYER } from '../content/copy';
---

<section class="hidden-layer">
  <div class="container">
    <p class="eyebrow">{HIDDEN_LAYER.number} — {HIDDEN_LAYER.eyebrow}</p>
    <h2>{HIDDEN_LAYER.headline}</h2>

    <div class="body-col">
      {HIDDEN_LAYER.body.map((p) => (
        <p class="body-text">{p}</p>
      ))}
    </div>

    <p class="pullquote">{HIDDEN_LAYER.pullquote}</p>

    <div class="flows">
      <div class="flow">
        <p class="flow-label">Today</p>
        {HIDDEN_LAYER.before.map((step, i) => (
          <>
            <div class="flow-node">{step}</div>
            {i < HIDDEN_LAYER.before.length - 1 && <div class="flow-arrow">↓</div>}
          </>
        ))}
      </div>
      <div class="flow accent">
        <p class="flow-label accent">With .nomos</p>
        {HIDDEN_LAYER.after.map((step, i) => (
          <>
            <div class="flow-node accent">{step}</div>
            {i < HIDDEN_LAYER.after.length - 1 && <div class="flow-arrow accent">↓</div>}
          </>
        ))}
      </div>
    </div>

    <p class="closer">{HIDDEN_LAYER.closer}</p>
    <a class="paper-link" href={HIDDEN_LAYER.paperLink.href}>{HIDDEN_LAYER.paperLink.label} →</a>
  </div>
</section>

<style>
  .hidden-layer {
    padding: 140px 0;
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-primary);
    border-bottom: 1px solid var(--border-primary);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
  }

  h2 {
    font-family: var(--font-serif);
    font-weight: var(--font-medium);
    font-size: clamp(32px, 4vw, 54px);
    line-height: var(--leading-snug);
    max-width: 16ch;
    margin: 0 0 48px;
  }

  .body-col {
    max-width: 620px;
    margin-bottom: 48px;
  }

  .body-text {
    font-size: 19px;
    color: var(--text-secondary);
    margin: 0 0 12px;
  }

  .body-text:last-child {
    color: var(--text-primary);
    font-weight: var(--font-medium);
    margin-bottom: 0;
  }

  .pullquote {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(26px, 3vw, 38px);
    line-height: 1.3;
    max-width: 18ch;
    margin: 0 0 64px;
    color: var(--accent);
  }

  .flows {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    max-width: 640px;
    margin-bottom: 56px;
  }

  .flow {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .flow-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 16px;
  }

  .flow-label.accent {
    color: var(--accent);
  }

  .flow-node {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--border-strong);
    text-align: center;
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .flow-node.accent {
    border-color: var(--accent);
    color: var(--accent);
  }

  .flow-arrow {
    text-align: center;
    width: 100%;
    padding: 8px 0;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .flow-arrow.accent {
    color: var(--accent);
  }

  .closer {
    font-size: 19px;
    color: var(--text-primary);
    margin: 0 0 24px;
  }

  .paper-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: 0.06em;
    color: var(--accent);
    border-bottom: 1px solid var(--accent);
    padding-bottom: 2px;
  }

  @media (max-width: 640px) {
    .flows {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
