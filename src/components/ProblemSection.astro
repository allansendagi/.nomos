---
import { PROBLEM } from '../content/copy';
---

<section id="problem" class="problem">
  <div class="container">
    <p class="eyebrow">{PROBLEM.number} — {PROBLEM.eyebrow}</p>
    <h2>{PROBLEM.headline}</h2>

    <div class="grid">
      {PROBLEM.examples.map((ex, i) => (
        <div class="cell">
          <div class="index">{String(i + 1).padStart(2, '0')}</div>
          {ex}
        </div>
      ))}
    </div>

    <p class="pullquote">{PROBLEM.pullquote}</p>

    {PROBLEM.body.map((p, i) => (
      <p class:list={['body', { emphasis: i === PROBLEM.body.length - 1 }]}>{p}</p>
    ))}
  </div>
</section>

<style>
  .problem {
    padding: 140px 0;
  }

  h2 {
    font-family: var(--font-serif);
    font-weight: var(--font-medium);
    font-size: clamp(32px, 4vw, 54px);
    line-height: var(--leading-snug);
    max-width: 14ch;
    margin: 0 0 56px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1px;
    background: var(--border-primary);
    border: 1px solid var(--border-primary);
    margin-bottom: 64px;
  }

  .cell {
    background: var(--bg-primary);
    padding: 32px;
    font-size: var(--text-base);
  }

  .index {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-bottom: 10px;
  }

  .pullquote {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(26px, 3vw, 38px);
    line-height: 1.3;
    max-width: 16ch;
    margin: 0 0 56px;
    color: var(--text-primary);
  }

  .body {
    font-size: 19px;
    max-width: 680px;
    color: var(--text-secondary);
    margin: 0 0 16px;
  }

  .body:last-child {
    margin-bottom: 0;
  }

  .body.emphasis {
    color: var(--text-primary);
    font-weight: var(--font-medium);
  }
</style>
