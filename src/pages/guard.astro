---
import BaseLayout from '../layouts/BaseLayout.astro';
import { GUARD } from '../content/copy';
---

<BaseLayout
  title="NOMOS Guard — The MCP Authority Gateway | .nomos"
  description="Govern every MCP tool call before it executes. NOMOS Guard checks agent actions against sealed .nomos artifacts — deterministic verdicts, cryptographic audit trail, zero code changes to your servers."
>
  <section class="hero">
    <div class="inner">
      <p class="eyebrow">{GUARD.index} — {GUARD.tag}</p>
      <h1>{GUARD.title}</h1>
      <p class="dek">{GUARD.layerLabel}</p>
      <p class="body-text">{GUARD.body}</p>
    </div>
  </section>

  <section class="content">
    <div class="inner">
      <div class="guard-flow">
        <div class="flow-box">{GUARD.flowBoxes[0]}</div>
        <div class="flow-arrow-label">{GUARD.flowLabels[0]} ↓</div>
        <div class="flow-box accent">{GUARD.flowBoxes[1]}</div>
        <div class="flow-arrow-label">{GUARD.flowLabels[1]} ↓</div>
        <div class="flow-box">{GUARD.flowBoxes[2]}</div>
      </div>

      <div class="mcp-panel">
        <p class="col-label">{GUARD.mcpDetail.label}</p>
        <p class="mcp-body">{GUARD.mcpDetail.body}</p>
        <div class="install-row">
          <code class="install-cmd">{GUARD.mcpDetail.install}</code>
          <p class="install-note">{GUARD.mcpDetail.installNote}</p>
        </div>
      </div>

      <p class="col-label section-label">{GUARD.paths.label}</p>

      <div class="path-block">
        <p class="path-name">{GUARD.paths.direct.name}</p>
        <p class="path-body">{GUARD.paths.direct.body}</p>
        <div class="tool-chips">
          {GUARD.paths.direct.tools.map((t) => <code class="tool-chip">{t}</code>)}
        </div>
      </div>

      <div class="path-block accent">
        <p class="path-name accent">{GUARD.paths.gateway.name}</p>
        <p class="path-body">{GUARD.paths.gateway.body}</p>
        <ul class="examples-list">
          {GUARD.paths.gateway.examples.map((ex) => <li>{ex}</li>)}
        </ul>
        <pre class="wrap-command"><code>{GUARD.paths.gateway.wrapCommand}</code></pre>
      </div>

      <div class="transcript-panel">
        <p class="col-label">{GUARD.transcript.label}</p>
        <div class="transcript">
          {GUARD.transcript.lines.map((line) => (
            <p class:list={['t-line', `t-${line.who}`]}>
              {line.who === 'agent' && <span class="t-prefix">Agent:</span>}
              {line.text}
            </p>
          ))}
        </div>
        <p class="transcript-note">{GUARD.transcript.note}</p>
      </div>
    </div>
  </section>

  <section class="quote-section">
    <p class="quote">{GUARD.summary}</p>
    <a
      class="live-link"
      href="https://www.nomosprotocol.com/mcp"
      target="_blank"
      rel="noopener noreferrer">Full MCP setup, API keys &amp; playground — live ↗</a
    >
    <a class="back" href="/#platform">← Back to the ecosystem</a>
  </section>
</BaseLayout>

<style>
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
    text-align: center;
  }

  .hero {
    padding: 160px 48px 80px;
    text-align: center;
  }

  .hero .inner {
    max-width: 700px;
    margin: 0 auto;
  }

  h1 {
    font-family: var(--font-serif);
    font-weight: var(--font-medium);
    font-size: clamp(40px, 5.6vw, 68px);
    line-height: 1.1;
    margin: 0 0 16px;
  }

  .dek {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 24px;
  }

  .body-text {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    margin: 0;
  }

  .content {
    padding: 0 48px 120px;
  }

  .content .inner {
    max-width: 700px;
    margin: 0 auto;
  }

  .guard-flow {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 420px;
    margin: 0 auto 64px;
  }

  .flow-box {
    width: 100%;
    padding: 16px 20px;
    border: 1px solid var(--border-strong);
    text-align: center;
  }

  .flow-box.accent {
    border-color: var(--accent);
    color: var(--accent);
  }

  .flow-arrow-label {
    text-align: center;
    width: 100%;
    color: var(--accent);
    padding: 10px 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .col-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 14px;
  }

  .mcp-panel {
    background: var(--bg-elevated);
    border: 1px solid var(--border-primary);
    padding: 32px;
  }

  .mcp-body {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0 0 28px;
  }

  .install-row {
    border-top: 1px solid var(--border-primary);
    padding-top: 24px;
  }

  .install-cmd {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: var(--accent);
    background: var(--bg-primary);
    border: 1px solid var(--border-primary);
    padding: 10px 16px;
    margin-bottom: 12px;
  }

  .install-note {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin: 0;
  }

  .section-label {
    margin-top: 64px;
  }

  .path-block {
    border: 1px solid var(--border-primary);
    padding: 28px 32px;
    margin-bottom: 1px;
  }

  .path-block.accent {
    border-color: var(--accent-dim);
    background: color-mix(in oklch, var(--accent) 6%, var(--bg-primary));
  }

  .path-name {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: 0.04em;
    color: var(--text-primary);
    margin-bottom: 10px;
  }

  .path-name.accent {
    color: var(--accent);
  }

  .path-body {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0 0 20px;
  }

  .tool-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tool-chip {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    border: 1px solid var(--border-primary);
    padding: 6px 12px;
  }

  .examples-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin: 0 0 24px;
    padding: 0;
  }

  .examples-list li::before {
    content: '— ';
    color: var(--text-muted);
  }

  .wrap-command {
    background: var(--bg-elevated);
    border: 1px solid var(--border-primary);
    padding: 16px 20px;
    margin: 0;
    overflow-x: auto;
  }

  .wrap-command code {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    white-space: pre;
  }

  .transcript-panel {
    margin-top: 64px;
  }

  .transcript {
    background: var(--bg-elevated);
    border: 1px solid var(--border-primary);
    padding: 24px 28px;
    margin-bottom: 16px;
  }

  .t-line {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.8;
    margin: 0 0 4px;
    color: var(--text-secondary);
  }

  .t-prefix {
    color: var(--text-muted);
    margin-right: 6px;
  }

  .t-call {
    color: var(--text-primary);
  }

  .t-guard {
    color: var(--text-muted);
  }

  .t-verdict {
    color: oklch(0.65 0.2 25);
    font-weight: var(--font-medium);
  }

  .t-rule,
  .t-hash {
    color: var(--text-muted);
    font-size: var(--text-xs);
  }

  .transcript-note {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin: 0;
  }

  .quote-section {
    padding: 120px 48px;
    text-align: center;
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-primary);
  }

  .quote {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    color: var(--accent);
    margin: 0 0 32px;
  }

  .live-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--bg-primary);
    background: var(--accent);
    padding: 14px 28px;
    margin-bottom: 28px;
    transition: filter var(--transition-fast);
  }

  .live-link:hover {
    filter: brightness(1.1);
  }

  .back {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .back:hover {
    color: var(--accent);
  }
</style>
