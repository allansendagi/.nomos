---
import BaseLayout from '../layouts/BaseLayout.astro';
import { REGISTRY } from '../content/copy';
---

<BaseLayout
  title="NOMOS Registry — Govern Authority | .nomos"
  description="The system of record for institutional authority: versioning, approval workflows, distribution, and full audit history for every sealed .nomos artifact."
>
  <section class="hero">
    <div class="inner">
      <p class="eyebrow">{REGISTRY.index} — {REGISTRY.tag}</p>
      <h1>{REGISTRY.title}</h1>
      <p class="dek">{REGISTRY.layerLabel}</p>
      <p class="body-text">{REGISTRY.body}</p>
      <p class="analogy">{REGISTRY.analogy}</p>
    </div>
  </section>

  <section class="content">
    <div class="inner">
      <div class="version-chain">
        {REGISTRY.versionChain.map((v, i) => (
          <>
            <span class:list={['version-node', { accent: i === REGISTRY.versionChain.length - 1 }]}>{v}</span>
            {i < REGISTRY.versionChain.length - 1 && <span class="chain-arrow">→</span>}
          </>
        ))}
      </div>

      <p class="col-label">Questions it answers</p>
      <div class="questions">
        {REGISTRY.questions.map((q) => <div>— {q}</div>)}
      </div>
    </div>
  </section>

  <section class="quote-section">
    <p class="quote">{REGISTRY.summary}</p>
    <a
      class="live-link"
      href="https://www.nomosprotocol.com/library"
      target="_blank"
      rel="noopener noreferrer">Browse the Artifact Library — live ↗</a
    >
    <a class="back" href="/#platform">← Back to the ecosystem</a>
  </section>
</BaseLayout>

<style>
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
    text-align: center;
  }

  .hero {
    padding: 160px 48px 80px;
    text-align: center;
  }

  .hero .inner {
    max-width: 700px;
    margin: 0 auto;
  }

  h1 {
    font-family: var(--font-serif);
    font-weight: var(--font-medium);
    font-size: clamp(40px, 5.6vw, 68px);
    line-height: 1.1;
    margin: 0 0 16px;
  }

  .dek {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 24px;
  }

  .body-text {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    margin: 0 0 20px;
  }

  .analogy {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--text-primary);
    margin: 0;
  }

  .content {
    padding: 0 48px 120px;
  }

  .content .inner {
    max-width: 700px;
    margin: 0 auto;
  }

  .col-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 14px;
  }

  .version-chain {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    margin-bottom: 56px;
  }

  .version-node {
    border: 1px solid var(--border-strong);
    padding: 12px 18px;
    color: var(--text-secondary);
  }

  .version-node.accent {
    border-color: var(--accent);
    color: var(--accent);
  }

  .chain-arrow {
    color: var(--accent);
  }

  .questions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px 32px;
    font-size: var(--text-base);
    color: var(--text-secondary);
  }

  .quote-section {
    padding: 120px 48px;
    text-align: center;
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-primary);
  }

  .quote {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    color: var(--accent);
    margin: 0 0 32px;
  }

  .live-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--bg-primary);
    background: var(--accent);
    padding: 14px 28px;
    margin-bottom: 28px;
    transition: filter var(--transition-fast);
  }

  .live-link:hover {
    filter: brightness(1.1);
  }

  .back {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .back:hover {
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .questions {
      grid-template-columns: 1fr;
    }
  }
</style>
