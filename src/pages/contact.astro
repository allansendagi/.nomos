---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | .nomos"
  description="Talk to the NOMOS team about computable authority — for governments, enterprises evaluating AI operators, and developers building on the protocol."
>
  <section class="contact">
    <div class="container">
      <p class="eyebrow">CONTACT</p>
      <h1>Let's talk about provable authority.</h1>
      <p class="lede">
        Whether you're a government body, an enterprise evaluating AI operators, or a developer
        building on the protocol — reach out directly.
      </p>

      <div class="channels">
        <a class="channel" href="mailto:allan@nomosprotocol.com">
          <span class="label">Email</span>
          <span class="value">allan@nomosprotocol.com</span>
        </a>
        <div class="channel">
          <span class="label">Phone</span>
          <span class="value">+974 5017 6561 · +971 52 846 3096</span>
        </div>
        <a class="channel" href="https://github.com/nomos-spec/spec" target="_blank" rel="noopener noreferrer">
          <span class="label">Open spec</span>
          <span class="value">github.com/nomos-spec/spec</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact {
    padding: var(--space-20) 0 var(--space-24);
  }

  h1 {
    font-family: var(--font-serif);
    font-weight: var(--font-medium);
    font-size: clamp(34px, 4.6vw, 58px);
    line-height: var(--leading-tight);
    margin: 0 0 var(--space-6);
    max-width: 14ch;
  }

  .lede {
    font-size: 19px;
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    max-width: 560px;
    margin-bottom: var(--space-16);
  }

  .channels {
    display: flex;
    flex-direction: column;
    max-width: 480px;
  }

  .channel {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-6) 0;
    border-top: 1px solid var(--border-primary);
    color: inherit;
  }

  .channels a.channel:hover .value {
    color: var(--accent);
  }

  .channels > *:last-child {
    border-bottom: 1px solid var(--border-primary);
  }

  .label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .value {
    font-size: var(--text-base);
    color: var(--text-primary);
    transition: color var(--transition-fast);
  }
</style>
