---
import BaseLayout from '../layouts/BaseLayout.astro';

const repoFiles = [
  { path: 'spec/NOMOS-SPEC-001.md', desc: 'Core protocol — rules, sealing, execution' },
  { path: 'spec/NOMOS-SPEC-002.md', desc: 'Multi-agent extension — agent manifests, guard phases, constraints DSL' },
  { path: 'spec/NOMOS-SPEC-003.md', desc: 'Temporal validity, staleness signalling, deterministic replay' },
  { path: 'spec/NOMOS-SPEC-004.md', desc: 'Composable artifacts (extends) and third-party attestations' },
  { path: 'schema/artifact.schema.json', desc: 'JSON Schema for .nomos artifact files' },
  { path: 'cli/nomos.ts', desc: 'CLI — validate, verify, exec, diff, lint' },
];
---

<BaseLayout
  title="Docs — NOMOS Protocol Specification, SDK & CLI | .nomos"
  description="The open .nomos specification: JSON schemas, TypeScript SDK, and CLI. Verify Ed25519-sealed governance artifacts offline with nothing but a public key."
>
  <section class="docs">
    <div class="container">
      <p class="eyebrow">DOCS</p>
      <h1>The NOMOS Protocol specification.</h1>
      <p class="lede">
        NOMOS is an open, vendor-neutral format for packaging governance policies as sealed,
        machine-executable artifacts. The full specification, schemas, CLI, and reference
        verifiers are published and MIT/CC-BY licensed.
      </p>

      <div class="block">
        <p class="label">TypeScript SDK</p>
        <pre><code>npm install @nomosprotocol/sdk</code></pre>
        <pre><code>{`import { Nomos } from '@nomosprotocol/sdk';

const nomos = new Nomos('nms_live_...');

const result = await nomos.decisions.verify({
  artifact_id:      'loan_approval_v1',
  decision_context: { credit_score: 720, loan_amount: 50_000 },
});

result.allowed      // true | false
result.verdict      // 'auto_approved' | 'auto_rejected' | 'escalated'
result.audit_record // SHA-256 — store for compliance`}</code></pre>
      </div>

      <div class="block">
        <p class="label">Verify a sealed artifact</p>
        <p class="body">
          Production artifacts are sealed with Ed25519 and are publicly verifiable — anyone can
          check the seal offline with the published public key, no secret and no call to the
          sealing authority.
        </p>
        <pre><code>npx tsx verify/verify.ts &lt;artifact.nomos&gt; --url https://nomosprotocol.com</code></pre>
      </div>

      <div class="block">
        <p class="label">Repository contents</p>
        <div class="files">
          {repoFiles.map((f) => (
            <a
              class="file"
              href={`https://github.com/nomos-spec/spec/blob/main/${f.path}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="path">{f.path}</span>
              <span class="desc">{f.desc}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="cta-row">
        <a class="repo-cta" href="https://github.com/nomos-spec/spec" target="_blank" rel="noopener noreferrer">
          View the full spec on GitHub ↗
        </a>
        <a class="live-cta" href="https://www.nomosprotocol.com/docs" target="_blank" rel="noopener noreferrer">
          Live API reference — nomosprotocol.com ↗
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .docs {
    padding: var(--space-20) 0 var(--space-24);
  }

  h1 {
    font-family: var(--font-serif);
    font-weight: var(--font-medium);
    font-size: clamp(34px, 4.6vw, 58px);
    line-height: var(--leading-tight);
    margin: 0 0 var(--space-6);
    max-width: 14ch;
  }

  .lede {
    font-size: 19px;
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    max-width: 640px;
    margin-bottom: var(--space-16);
  }

  .label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-4);
  }

  .block {
    margin-bottom: var(--space-16);
    max-width: 720px;
  }

  .block .body {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  pre {
    background: var(--bg-secondary);
    border: 1px solid var(--border-primary);
    padding: var(--space-5);
    overflow-x: auto;
    margin-bottom: var(--space-3);
  }

  code {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-primary);
    line-height: var(--leading-relaxed);
    white-space: pre;
  }

  .files {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--border-primary);
    border: 1px solid var(--border-primary);
  }

  .file {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: var(--bg-primary);
    transition: background var(--transition-fast);
  }

  .file:hover {
    background: var(--bg-secondary);
  }

  .path {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    flex-shrink: 0;
  }

  .desc {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    text-align: right;
  }

  .cta-row {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .repo-cta {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: 0.04em;
    color: var(--bg-primary);
    background: var(--text-primary);
    padding: var(--space-3) var(--space-6);
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .live-cta {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    border-bottom: 1px solid var(--accent);
    padding-bottom: 2px;
  }

  .repo-cta:hover {
    background: var(--accent);
    color: var(--bg-primary);
  }

  @media (max-width: 640px) {
    .file {
      flex-direction: column;
      align-items: flex-start;
    }
    .desc {
      text-align: left;
    }
  }
</style>
