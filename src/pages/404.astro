---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found | .nomos" description="This page does not exist." noindex>
  <section class="notfound">
    <p class="code">404</p>
    <h1>Not authorized to exist.</h1>
    <p class="body">This page isn't in the registry. The homepage is.</p>
    <a class="home-link" href="/">← Back to .nomos</a>
  </section>
</BaseLayout>

<style>
  .notfound {
    min-height: 70vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 0 24px;
  }

  .code {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: 0.14em;
    color: var(--accent);
    margin-bottom: 20px;
  }

  h1 {
    font-family: var(--font-serif);
    font-weight: var(--font-medium);
    font-size: clamp(32px, 5vw, 56px);
    margin: 0 0 16px;
  }

  .body {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    margin-bottom: 32px;
  }

  .home-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    border-bottom: 1px solid var(--accent);
    padding-bottom: 2px;
  }
</style>
