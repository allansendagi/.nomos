---
import BaseLayout from '../layouts/BaseLayout.astro';
import { STUDIO } from '../content/copy';
---

<BaseLayout
  title="NOMOS Studio — Create Authority Artifacts | .nomos"
  description="Compile policies, regulations, and institutional logic into signed .nomos artifacts. See a real KHDA school-fee policy become a machine-executable rule."
>
  <section class="hero">
    <div class="inner">
      <p class="eyebrow">{STUDIO.index} — {STUDIO.tag}</p>
      <h1>{STUDIO.title}</h1>
      <p class="dek">{STUDIO.layerLabel}</p>
      <p class="body-text">{STUDIO.body}</p>
    </div>
  </section>

  <section class="content">
    <div class="inner">
      <div class="io-grid">
        <div>
          <p class="col-label">Input</p>
          <div class="plain-list">
            {STUDIO.input.map((item) => <div>{item}</div>)}
          </div>
        </div>
        <div>
          <p class="col-label">Output</p>
          <p class="output-value">{STUDIO.output}</p>
        </div>
      </div>

      <div class="example">
        <p class="example-before">{STUDIO.exampleBefore}</p>
        <p class="example-arrow">↓ becomes</p>
        <pre><code>{STUDIO.exampleAfter}</code></pre>
      </div>
    </div>
  </section>

  <section class="quote-section">
    <p class="quote">{STUDIO.summary}</p>
    <a
      class="live-link"
      href="https://www.nomosprotocol.com/studio"
      target="_blank"
      rel="noopener noreferrer">Open NOMOS Studio — live ↗</a
    >
    <a class="back" href="/#platform">← Back to the ecosystem</a>
  </section>
</BaseLayout>

<style>
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
    text-align: center;
  }

  .hero {
    padding: 160px 48px 80px;
    text-align: center;
  }

  .hero .inner {
    max-width: 700px;
    margin: 0 auto;
  }

  h1 {
    font-family: var(--font-serif);
    font-weight: var(--font-medium);
    font-size: clamp(40px, 5.6vw, 68px);
    line-height: 1.1;
    margin: 0 0 16px;
  }

  .dek {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 24px;
  }

  .body-text {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    margin: 0;
  }

  .content {
    padding: 0 48px 120px;
  }

  .content .inner {
    max-width: 700px;
    margin: 0 auto;
  }

  .col-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 14px;
  }

  .io-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    margin-bottom: 48px;
  }

  .plain-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: var(--text-base);
    color: var(--text-secondary);
  }

  .output-value {
    color: var(--accent);
    margin: 0;
  }

  .example {
    background: var(--bg-elevated);
    border: 1px solid var(--border-primary);
    padding: 32px;
  }

  .example-before {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--text-secondary);
    margin: 0 0 20px;
  }

  .example-arrow {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    margin: 0 0 20px;
  }

  pre {
    margin: 0;
    overflow-x: auto;
  }

  code {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.8;
    color: var(--text-secondary);
    white-space: pre;
  }

  .quote-section {
    padding: 120px 48px;
    text-align: center;
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-primary);
  }

  .quote {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    color: var(--accent);
    margin: 0 0 32px;
  }

  .live-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--bg-primary);
    background: var(--accent);
    padding: 14px 28px;
    margin-bottom: 28px;
    transition: filter var(--transition-fast);
  }

  .live-link:hover {
    filter: brightness(1.1);
  }

  .back {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .back:hover {
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .io-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>
